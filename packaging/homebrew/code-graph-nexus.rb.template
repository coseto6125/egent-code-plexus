# Homebrew tap formula template for coseto6125/homebrew-tap.
#
# Release automation should replace:
#   @VERSION@
#   @SHA256_ARM64_DARWIN@
#   @SHA256_X86_64_DARWIN@
#
# Expected GitHub Release assets:
#   cgn-v@VERSION@-aarch64-apple-darwin.tar.gz
#   cgn-v@VERSION@-x86_64-apple-darwin.tar.gz

class GraphNexus < Formula
  desc "Code intelligence graph CLI for LLM agents"
  homepage "https://github.com/coseto6125/code-graph-nexus"
  license "MIT OR Apache-2.0"
  version "@VERSION@"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/coseto6125/code-graph-nexus/releases/download/v#{version}/cgn-v#{version}-aarch64-apple-darwin.tar.gz"
      sha256 "@SHA256_ARM64_DARWIN@"
    else
      url "https://github.com/coseto6125/code-graph-nexus/releases/download/v#{version}/cgn-v#{version}-x86_64-apple-darwin.tar.gz"
      sha256 "@SHA256_X86_64_DARWIN@"
    end
  end

  def install
    bin.install "cgn"
  end

  test do
    system "#{bin}/cgn", "--version"
  end
end
