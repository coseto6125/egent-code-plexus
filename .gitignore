# --- Git / Version Control ---
.git/
/.gitnexus/
/.worktrees/

# --- Rust Build & IDE ---
target/
.rustfmt.toml

# --- Python ---
__pycache__/
*.pyc
*.pyo
.ruff_cache/
.venv/
env/
venv/

# --- AI Tools & Editor (Per-user) ---
.claude/
.gemini/
CLAUDE.md
.fastembed_cache/

# --- Project Specific (CGN) ---
/.cgn/
/.codegraph/
/.sample_repo/

# --- Parity Test Artifacts ---
# Transient analysis artefacts, regenerated on demand
scripts/parity/symbol_diffs/
scripts/parity/review/
# Dev-local fixtures (generated per language)
tests/parity/fixtures/*/sample_project/
# Legacy/Specific test artifacts
tests/parity/fixtures/basic/.gitnexus-rs/

# --- Vendored 3rd-party Grammars ---
# Keep src/queries/bindings, drop build bloat
crates/vendor/*/node_modules/
crates/vendor/*/.git/
crates/vendor/*/build/

# --- Local Backups & Temporary Files ---
.local-backups-*/
/test*.py
/test*.rs
/test*.js
/test*.ts
/test*.java
/test*.rb
/test*.scm
/fix_*.py
/refactor_*.py
/optimize_*.py
/update_*.py

# Cache and node artifacts
.codegraph
