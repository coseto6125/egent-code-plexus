.source_code/
.sample_repo/

# Parity test fixtures (dev-local, generated per language)
tests/parity/fixtures/*/sample_project/

# Parity per-symbol diff output (transient analysis artefacts, regenerated on demand)
scripts/parity/symbol_diffs/
scripts/parity/review/

# Python bytecode caches anywhere in repo (scripts/parity/, tools/, etc.)
__pycache__/
*.pyc
*.pyo

# Rust build
target/

# AI tool config / caches (per-user)
.claude/
.gemini/
.fastembed_cache/
CLAUDE.md

# Local index
.gitnexus-rs/
.cgn/

# Vendored 3rd-party grammar repos: keep src/queries/bindings, drop bloat
crates/vendor/*/node_modules/
crates/vendor/*/.git/
crates/vendor/*/build/

# Local backup snapshots (per-user, date-stamped)
.local-backups-*/

# Scratch / one-off migration scripts (repo root)
/test*.py
/test*.rs
/test*.js
/test*.ts
/test*.java
/test*.rb
/test*.scm
/fix_*.py
/refactor_*.py
/optimize_*.py
/update_*.py
